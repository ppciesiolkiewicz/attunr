# PostHog — analytics event tracking
# Get from PostHog → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Facebook App ID — required for Messenger/Facebook link previews
# Create at https://developers.facebook.com → Settings → Basic
NEXT_PUBLIC_FB_APP_ID=

# Vercel Blob Storage — base URL for voice exercise audio files
NEXT_PUBLIC_VOICE_BASE_URL=

# PostHog Personal API Key — required for `npm run analytics:*` CLI scripts
# Create at PostHog → Settings → Personal API Keys (read access on Project + Query)
POSTHOG_PERSONAL_API_KEY=

# ElevenLabs — voice audio generation
# Get from https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=

# Vercel Blob Storage — read/write token for uploading assets
# Get from Vercel → Project → Storage → Blob → Tokens
ATTUNR_BLOB_READ_WRITE_TOKEN=
